generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Transaction {
  id        String   @id @default(uuid())
  item      String
  amount    Float
  type      String
  category  String
  merchant  String
  bank      String?
  datetime  DateTime
  reference String?
  createdAt DateTime @default(now())
}

model AlphaWhitelistKey {
  code           String   @id
  isUsed         Boolean  @default(false)
  usedByEmail    String?
  usedByUsername String?
  usedAt         DateTime?
  createdAt      DateTime @default(now())

  @@index([isUsed, createdAt])
}

model DashboardPreference {
  userId    String   @id
  lang      String   @default("th")
  capsJson  String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
