generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Transaction {
  id        String   @id @default(uuid())
  item      String
  amount    Float
  type      String
  category  String
  merchant  String
  bank      String?
  datetime  DateTime
  reference String?
  createdAt DateTime @default(now())
}
